---
import { BookOpen, ExternalLink, GitBranch, ShieldCheck } from "@lucide/astro";
---

<section class="code-map landing-shell" aria-labelledby="code-map-heading">
  <div class="landing-section-copy">
    <p class="landing-kicker">Built around real automation</p>
    <h2 id="code-map-heading" class="landing-section-title">
      Every visual decision maps to a file your team can review.
    </h2>
  </div>

  <div class="code-map__grid">
    <article class="code-map__panel" data-reveal>
      <div class="landing-panel__bar">
        <span>visual workflow</span>
        <span>source</span>
      </div>
      <ul>
        <li><span>Node</span><strong>Open checkout</strong></li>
        <li><span>Locator</span><strong>getByRole("button")</strong></li>
        <li><span>Parameter</span><strong>couponCode</strong></li>
        <li><span>Assertion</span><strong>total equals "$29"</strong></li>
      </ul>
    </article>

    <article class="code-map__panel code-map__panel--output" data-reveal>
      <div class="landing-panel__bar">
        <span>repository output</span>
        <span>generated</span>
      </div>
      <ul>
        <li><span>.feature</span><strong>Cucumber scenario</strong></li>
        <li><span>.spec.ts</span><strong>Playwright execution</strong></li>
        <li><span>steps.ts</span><strong>Reusable glue code</strong></li>
        <li><span>reports</span><strong>Logs and evidence</strong></li>
      </ul>
    </article>
  </div>
</section>

<section class="docs-preview landing-shell" aria-labelledby="docs-preview-heading">
  <div class="docs-preview__copy">
    <p class="landing-kicker">Documentation preview</p>
    <h2 id="docs-preview-heading" class="landing-section-title">
      Start from the workflow you need.
    </h2>
  </div>
  <div class="docs-preview__grid">
    <a href="/getting-started/quick-start/" data-reveal>
      <BookOpen aria-hidden="true" />
      <span>Quick Start</span>
      <strong>Install, model, run, and inspect your first flow.</strong>
    </a>
    <a href="/build-tests/locators/" data-reveal>
      <ShieldCheck aria-hidden="true" />
      <span>Locator Builder</span>
      <strong>Create locator groups that survive UI changes.</strong>
    </a>
    <a href="/reference/architecture/execution-lifecycle/" data-reveal>
      <GitBranch aria-hidden="true" />
      <span>Execution Lifecycle</span>
      <strong>Understand generated files, runs, logs, and reports.</strong>
    </a>
  </div>
</section>

<section class="open-source landing-shell" aria-labelledby="open-source-heading">
  <div class="open-source__copy">
    <p class="landing-kicker">Open source</p>
    <h2 id="open-source-heading" class="landing-section-title">
      No vendor lock-in. No hidden runner. No black boxes.
    </h2>
    <p class="landing-section-description">
      AppraiseJS is built around repositories, pull requests, and automation
      artifacts that remain useful outside the visual editor.
    </p>
  </div>
  <a
    class="open-source__link"
    href="https://github.com/jamil2018/appraisejs-core"
    target="_blank"
    rel="noopener noreferrer"
  >
    <ExternalLink aria-hidden="true" />
    View GitHub Repository
  </a>
</section>
