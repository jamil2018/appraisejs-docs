<section
  class="landing-features landing-shell"
  aria-labelledby="landing-features-heading"
>
  <div class="landing-section-copy landing-section-copy--center">
    <h2 id="landing-features-heading" class="landing-section-title">
      Precision-Engineered Tooling
    </h2>
  </div>

  <div class="landing-feature-grid">
    <article class="landing-feature-card landing-feature-card--builder">
      <div class="landing-feature-card__copy">
        <h3>Visual Test Builder</h3>
        <p>
          The most advanced node editor ever built for QA. Real-time sync,
          branching logic, and reusable sub-flows.
        </p>
      </div>
      <div class="landing-builder-visual" aria-hidden="true">
        <div class="landing-builder-visual__frame">
          <div class="landing-builder-node">
            <span>NAVIGATE</span>
            <strong>Base URL</strong>
          </div>
          <div class="landing-builder-node__line"></div>
          <div class="landing-builder-node">
            <span>INPUT</span>
            <strong>Fill Email</strong>
          </div>
          <div class="landing-builder-node__line"></div>
          <div class="landing-builder-node landing-builder-node--active">
            <span>CLICK</span>
            <strong>Login</strong>
          </div>
        </div>
      </div>
    </article>

    <article class="landing-feature-card landing-feature-card--compact">
      <div class="landing-locator-visual" aria-hidden="true">
        <span class="landing-locator-label">#btn</span>
        <span class="landing-locator-target"></span>
        <span class="landing-locator-label landing-locator-label--right">
          .submit
        </span>
      </div>
      <div class="landing-feature-card__copy">
        <h3>Locator Creator</h3>
        <p>Intelligent selector generation that survives DOM changes.</p>
      </div>
    </article>

    <article class="landing-feature-card landing-feature-card--compact">
      <div class="landing-sync-visual" aria-hidden="true">
        <span class="landing-sync-visual__file"></span>
        <span class="landing-sync-visual__line"></span>
        <span class="landing-sync-visual__node"></span>
      </div>
      <div class="landing-feature-card__copy">
        <h3>Sync Manager</h3>
        <p>Bidirectional sync between visual UI and your code repo.</p>
      </div>
    </article>

    <article class="landing-feature-card landing-feature-card--reporting">
      <div class="landing-report-visual" aria-hidden="true">
        <span
          class="landing-report-visual__bar landing-report-visual__bar--short"
        ></span>
        <span
          class="landing-report-visual__bar landing-report-visual__bar--medium"
        ></span>
        <span
          class="landing-report-visual__bar landing-report-visual__bar--tall"
        ></span>
        <span
          class="landing-report-visual__bar landing-report-visual__bar--full"
        ></span>
      </div>
      <div class="landing-feature-card__copy">
        <h3>Reporting &amp; Log Analysis</h3>
        <p>
          Deep-dive into test results with integrated log analysis and visual
          diffs.
        </p>
      </div>
    </article>

    <article class="landing-feature-card landing-feature-card--terminal">
      <div class="landing-terminal-list" aria-hidden="true">
        <div class="landing-terminal-item">
          <span>npm test</span>
          <span class="landing-terminal-item__status"></span>
        </div>
        <div class="landing-terminal-item">
          <span>npx playwright test</span>
          <span
            class="landing-terminal-item__status landing-terminal-item__status--bolt"
          ></span>
        </div>
      </div>
      <div class="landing-feature-card__copy">
        <h3>Local-First Execution</h3>
        <p>
          No proprietary cloud runners required. Your hardware, your speed, your
          privacy.
        </p>
      </div>
    </article>
  </div>
</section>
