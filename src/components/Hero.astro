---
import { CirclePlay } from "@lucide/astro";
---

<section
  class="landing-hero landing-shell"
  aria-labelledby="landing-hero-heading"
>
  <div class="landing-hero__copy">
    <p class="landing-badge">Visual Orchestration for Modern QA</p>
    <h1 id="landing-hero-heading">
      <span>Design Tests Visually.</span>
      <span class="landing-accent-text">Execute with Real Code.</span>
    </h1>
    <p class="landing-hero__description">
      Build end-to-end flows with an intuitive node editor. AppraiseJS emits
      standard Playwright and Cucumber files directly to your repo. Zero
      lock-in, pure engineering.
    </p>
    <div class="landing-hero__actions">
      <a class="landing-cta-button" href="/getting-started/quick_start/">
        Get Started
      </a>
      <a
        class="landing-secondary-button"
        href="/getting-started/overview/#see-it-in-action"
      >
        <span class="landing-play-icon" aria-hidden="true">
          <CirclePlay />
        </span>
        Watch Demo
      </a>
    </div>
  </div>

  <div class="landing-hero__visual" aria-hidden="true">
    <div class="landing-hero__visual-glow"></div>
    <div class="landing-hero__visual-frame">
      <div class="landing-hero__visual-side landing-hero__visual-side--flow">
        <div class="landing-windowbar">
          <span class="dot dot--rose"></span>
          <span class="dot dot--mint"></span>
          <span class="dot dot--green"></span>
          <span class="landing-windowbar__label">VISUAL_NODE_EDITOR</span>
        </div>
        <div class="landing-flow">
          <div class="landing-flow__connector"></div>
          <div class="landing-flow__connector landing-flow__connector--middle">
          </div>
          <article class="landing-flow-card landing-flow-card--active">
            <span class="landing-flow-card__kind">Trigger</span>
            <strong>User Login</strong>
            <span class="landing-flow-card__terminal"></span>
          </article>
          <article class="landing-flow-card">
            <span
              class="landing-flow-card__kind landing-flow-card__kind--muted"
            >
              Action
            </span>
            <strong>Click "Checkout"</strong>
            <span class="landing-flow-card__terminal"></span>
          </article>
          <article class="landing-flow-card landing-flow-card--success">
            <span
              class="landing-flow-card__kind landing-flow-card__kind--success"
            >
              Assertion
            </span>
            <strong>{"Cart Total > $100"}</strong>
          </article>
        </div>
      </div>

      <div class="landing-hero__visual-side landing-hero__visual-side--code">
        <div class="landing-code__header">
          <span class="landing-code__label">CUCUMBER_GHERKIN_OUTPUT</span>
          <span class="landing-code__chip">checkout.feature</span>
        </div>
        <div class="landing-code">
          <p class="landing-code-line">
            <span class="syntax-keyword">Feature:</span>
            <span class="syntax-text"> Checkout Validation</span>
          </p>
          <p class="landing-code-line landing-code-line--indent-1">
            <span class="syntax-keyword">Scenario:</span>
            <span class="syntax-text"> Verify high value cart checkout</span>
          </p>
          <p class="landing-code-line landing-code-line--indent-2">
            <span class="syntax-accent">Given</span>
            <span class="syntax-text">
              the user is logged in as "test_user"</span
            >
          </p>
          <p class="landing-code-line landing-code-line--indent-2">
            <span class="syntax-accent">When</span>
            <span class="syntax-text">
              {" "}the user clicks the "Checkout" button
            </span>
          </p>
          <p class="landing-code-line landing-code-line--indent-2">
            <span class="syntax-accent">Then</span>
            <span class="syntax-text">
              {" "}the cart total should be greater than 100
            </span>
          </p>
          <p class="landing-code-note"># Human readable specs derived</p>
          <p class="landing-code-note"># directly from visual nodes.</p>
        </div>
      </div>
    </div>
  </div>
</section>
