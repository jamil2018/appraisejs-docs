---
/**
 * Landing: trust strip — built-with / compatibility pills, centered beneath the hero.
 */
const pills = [
  "Local-first workflow",
  "Playwright compatible",
  "Cucumber artifact output",
  "TypeScript-ready pipelines",
  "CI orchestration support",
];
---

<section class="landing-trust landing-panel" aria-label="Built with">
  <p class="landing-trust__label">Built for teams shipping every week</p>
  <div class="landing-trust__list">
    {pills.map((label) => (
      <span class="landing-trust__pill">{label}</span>
    ))}
  </div>
</section>

<style is:global>
  .landing-trust {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .landing-trust__label {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }

  .landing-trust__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
    align-items: center;
  }

  .landing-trust__pill {
    display: inline-block;
    padding: 0.4rem 0.78rem;
    font-size: 0.76rem;
    font-weight: 500;
    color: hsl(var(--secondary-foreground));
    background: hsl(var(--secondary) / 0.6);
    border: 1px solid hsl(var(--border));
    border-radius: 9999px;
  }
</style>
