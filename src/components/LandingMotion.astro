---
/**
 * Client-side Motion (motion.dev) animations for the landing page.
 * Runs only when this component mounts (landing page). Uses consistent
 * duration/easing across hero, sections, and cards. Respects prefers-reduced-motion.
 */
---

<div
  class="landing-motion-root"
  aria-hidden="true"
  style="position: absolute; width: 0; height: 0; overflow: hidden;"
>
  <script>
    // @ts-nocheck - Motion types are strict; API is correct per motion.dev/docs
    import { animate, inView, stagger } from "motion";

    const prefersReducedMotion = () =>
      typeof window !== "undefined" &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const opts = { duration: 0.5, ease: [0.25, 0.1, 0.25, 1] };
    const optsFast = { duration: 0.35, ease: [0.25, 0.1, 0.25, 1] };

    function run() {
      if (prefersReducedMotion()) return;

      const hero = document.querySelector(".landing-hero");
      const productVisual = document.querySelector(".landing-product-visual");

      if (hero) {
        animate(hero, { opacity: [0, 1], y: [14, 0] }, opts);
      }
      if (productVisual) {
        animate(
          productVisual,
          { opacity: [0, 1], y: [8, 0] },
          { delay: 0.15, ...optsFast },
        );
      }

      inView(".landing-trust", (el) => {
        animate(el, { opacity: [0, 1], y: [12, 0] }, opts);
      });
      inView(".landing-problem", (el) => {
        animate(el, { opacity: [0, 1], y: [16, 0] }, opts);
        const grid = el.querySelector(".landing-problem__grid");
        if (grid && grid.children.length) {
          animate(
            grid.children,
            { opacity: [0, 1], y: [12, 0] },
            { delay: stagger(0.06), duration: 0.4, ease: [0.25, 0.1, 0.25, 1] },
          );
        }
      });
      inView(".landing-features", (el) => {
        animate(el, { opacity: [0, 1], y: [16, 0] }, opts);
        const grid = el.querySelector(".landing-features-grid");
        if (grid && grid.children.length) {
          animate(
            grid.children,
            { opacity: [0, 1], y: [12, 0] },
            { delay: stagger(0.06), duration: 0.4, ease: [0.25, 0.1, 0.25, 1] },
          );
        }
      });
      inView(".landing-demo", (el) => {
        animate(el, { opacity: [0, 1], y: [16, 0] }, opts);
      });
      inView(".landing-cta-panel", (el) => {
        animate(el, { opacity: [0, 1], y: [10, 0] }, { ...opts, delay: 0.1 });
      });
    }

    run();
  </script>
</div>
