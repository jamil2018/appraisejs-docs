---
/**
 * Landing: "See it in action" two-column—left copy + bullets, right code card.
 */
const bullets = [
  'Create a project in minutes.',
  'Compose tests visually, export standard artifacts.',
  'Run locally or in CI and inspect results.',
];
---

<section class="landing-panel landing-demo" aria-labelledby="demo-heading">
  <p class="landing-kicker">SEE IT IN ACTION</p>
  <h2 id="demo-heading" class="landing-heading">From idea to run in one flow.</h2>
  <div class="landing-demo__grid">
    <div class="landing-demo__copy">
      <p class="landing-demo__intro">
        AppraiseJS gives you a single local app to define test assets, generate Gherkin artifacts, and run with Playwright. No glue code—just a clear path from authoring to results.
      </p>
      <ul class="landing-demo__bullets">
        {bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    </div>
    <div class="landing-demo__code" aria-hidden="true">
      <pre><code>npm run setup
npm run sync-all
npm run dev</code></pre>
      <p class="landing-demo__code-caption">Then open the app and create your first run.</p>
    </div>
  </div>
</section>

<style is:global>
  .landing-demo__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  @media (min-width: 960px) {
    .landing-demo__grid {
      grid-template-columns: 1fr minmax(260px, 340px);
      gap: 2rem;
      align-items: start;
    }
  }

  .landing-demo__intro {
    margin: 0 0 1rem;
    color: var(--sl-color-text-accent);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .landing-demo__bullets {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--sl-color-text-accent);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .landing-demo__bullets li {
    margin-bottom: 0.35rem;
  }

  .landing-demo__code {
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: var(--sl-color-surface-1, color-mix(in oklab, var(--sl-color-text) 8%, var(--sl-color-bg)));
    border: 1px solid var(--sl-color-hairline, color-mix(in oklab, var(--sl-color-text) 12%, transparent));
  }

  .landing-demo__code pre {
    margin: 0 0 0.5rem;
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--sl-color-text);
    overflow-x: auto;
  }

  .landing-demo__code-caption {
    margin: 0;
    font-size: 0.75rem;
    color: var(--sl-color-text-accent);
  }
</style>
