---
const bullets = [
  "Model one business-critical journey in minutes.",
  "Generate and run production-ready Playwright + Cucumber artifacts.",
  "Debug from structured scenario reports, not brittle logs.",
];
---

<section class="landing-panel landing-demo" aria-labelledby="demo-heading">
  <p class="landing-kicker">Visual Preview</p>
  <h2 id="demo-heading" class="landing-heading">
    See how AppraiseJS keeps authoring and execution in one continuous loop.
  </h2>
  <div class="landing-demo__grid">
    <div class="landing-demo__copy">
      <p class="landing-demo__intro">
        AppraiseJS is designed like a product workspace, not a docs utility:
        journey modeling, execution orchestration, and report visibility live in
        one coherent flow with shared language for QA and engineering.
      </p>
      <ul class="landing-demo__bullets">
        {bullets.map((b) => <li>{b}</li>)}
      </ul>
    </div>
    <div class="landing-demo__visual landing-card" aria-hidden="true">
      <div class="landing-demo__visual-head">
        <span></span><span></span><span></span>
      </div>
      <div class="landing-demo__visual-body">
        <aside>
          <h3>Workspaces</h3>
          <ul>
            <li>Checkout Flow</li>
            <li>Billing Portal</li>
            <li>Onboarding</li>
          </ul>
        </aside>
        <article>
          <h4>Run Overview</h4>
          <div class="landing-demo__stats">
            <span><strong>42</strong> Scenarios</span>
            <span><strong>3</strong> Failing</span>
            <span><strong>8m</strong> Duration</span>
          </div>
          <div class="landing-demo__bars">
            <span style="--w: 92%;"></span>
            <span style="--w: 81%;"></span>
            <span style="--w: 66%;"></span>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .landing-demo__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
    margin-top: 0.5rem;
  }

  @media (min-width: 58rem) {
    .landing-demo__grid {
      grid-template-columns: 1fr minmax(20rem, 24rem);
      gap: 2rem;
      align-items: start;
    }
  }

  .landing-demo__intro {
    margin: 0 0 1rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .landing-demo__bullets {
    margin: 0;
    padding-left: 1rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .landing-demo__bullets li {
    margin-bottom: 0.35rem;
  }

  .landing-demo__visual {
    border-color: hsl(var(--border) / 0.95);
    overflow: hidden;
    position: relative;
    background: hsl(var(--card));
  }

  .landing-demo__visual::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% auto;
    width: 14rem;
    height: 14rem;
    border-radius: 9999px;
    background: hsl(var(--accent) / 0.22);
    filter: blur(64px);
    pointer-events: none;
  }

  .landing-demo__visual-head {
    border-bottom: 1px solid hsl(var(--border));
    padding: 0.8rem;
    display: flex;
    gap: 0.32rem;
  }

  .landing-demo__visual-head span {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 9999px;
    background: hsl(var(--muted-foreground) / 0.5);
  }

  .landing-demo__visual-body {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 0.8rem;
    padding: 0.85rem;
  }

  .landing-demo__visual-body aside,
  .landing-demo__visual-body article {
    border-radius: calc(var(--radius) - 0.3rem);
    border: 1px solid hsl(var(--border));
    background: hsl(var(--secondary) / 0.5);
    padding: 0.75rem;
  }

  .landing-demo__visual-body h3,
  .landing-demo__visual-body h4 {
    margin: 0 0 0.55rem;
    font-size: 0.76rem;
    color: hsl(var(--card-foreground));
    font-weight: 600;
  }

  .landing-demo__visual-body ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.3rem;
  }

  .landing-demo__visual-body li {
    font-size: 0.72rem;
    color: hsl(var(--muted-foreground));
  }

  .landing-demo__stats {
    display: grid;
    gap: 0.34rem;
    margin-bottom: 0.6rem;
  }

  .landing-demo__stats span {
    font-size: 0.72rem;
    color: hsl(var(--muted-foreground));
  }

  .landing-demo__stats strong {
    color: hsl(var(--foreground));
  }

  .landing-demo__bars {
    display: grid;
    gap: 0.33rem;
  }

  .landing-demo__bars span {
    display: block;
    height: 0.35rem;
    border-radius: 9999px;
    width: var(--w);
    background: linear-gradient(
      to right,
      hsl(var(--primary)),
      hsl(var(--accent))
    );
  }
</style>
