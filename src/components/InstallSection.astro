---
/**
 * Landing section: Install with two options (npm scaffold, run from source).
 */
---

<section class="landing-panel landing-install" aria-labelledby="install-heading">
  <p class="landing-kicker">INSTALL</p>
  <h2 id="install-heading" class="landing-heading">From zero to running in under five minutes.</h2>
  <p class="landing-prereq">Prerequisites: Node.js 18+, npm</p>
  <div class="landing-command-strip">
    <span>npx</span>
    <code>create-appraisejs@latest</code>
  </div>
  <div class="landing-install-grid">
    <article class="landing-install-card">
      <h3>Use npm scaffold</h3>
      <pre><code>npx create-appraisejs@latest
cd &lt;your-project-name&gt;
npm run setup
npm run sync-all
npm run dev</code></pre>
    </article>
    <article class="landing-install-card">
      <h3>Run from source</h3>
      <pre><code>git clone https://github.com/jamil2018/appraisejs-core.git
cd appraisejs-core
npm run setup
npm run sync-all
npm run dev</code></pre>
    </article>
  </div>
</section>

<style is:global>
  .landing-install {
    margin-top: 0.5rem;
  }

  .landing-prereq {
    margin: 0.25rem 0 0.75rem;
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
  }

  .landing-command-strip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 9999px;
    padding: 0.4rem 0.85rem;
    background: var(--sl-color-surface-1, color-mix(in oklab, var(--sl-color-text) 8%, var(--sl-color-background)));
    margin-bottom: 1rem;
  }

  .landing-command-strip span {
    font-size: 0.8rem;
    color: var(--sl-color-text-accent);
    font-weight: 700;
  }

  .landing-command-strip code {
    font-size: 0.85rem;
    font-family: var(--sl-font-mono);
  }

  .landing-install-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .landing-install-card {
    border-radius: 0.5rem;
    padding: 0.9rem;
    background: var(--sl-color-surface-1, color-mix(in oklab, var(--sl-color-text) 6%, var(--sl-color-background)));
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .landing-install-card:hover {
    background: var(--sl-color-surface-2, color-mix(in oklab, var(--sl-color-text) 10%, var(--sl-color-background)));
    transform: translateY(-1px);
  }

  .landing-install-card h3 {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .landing-install-card pre {
    margin: 0;
    font-size: 0.8rem;
    overflow-x: auto;
  }

  .landing-install-card code {
    font-family: var(--sl-font-mono);
  }

  @media (max-width: 960px) {
    .landing-install-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-install-card:hover {
      transform: none;
    }
  }
</style>
