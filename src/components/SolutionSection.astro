---
const bullets = [
  {
    title: "Full Version Control",
    description:
      "Branch, merge, and PR your visual tests just like any other feature.",
  },
  {
    title: "Existing CI Stacks",
    description:
      "Works out of the box with GitHub Actions, GitLab CI, and Jenkins.",
  },
  {
    title: "Export Anytime",
    description:
      "Cancel your subscription and keep your code. It is yours forever.",
  },
];
---

<section
  class="landing-git landing-shell"
  aria-labelledby="landing-git-heading"
>
  <div class="landing-git__visual" aria-hidden="true">
    <div class="landing-git__visual-glow"></div>
    <div class="landing-git__visual-card">
      <span class="landing-git__corner landing-git__corner--top">
        <svg viewBox="0 0 40 32" fill="none">
          <path d="M8 10h8v8H8zM24 10h8v8h-8zM16 18h8v8h-8z"></path>
          <path d="M16 14h8M28 18v2M20 18v4"></path>
        </svg>
      </span>
      <span class="landing-git__corner landing-git__corner--bottom">
        <svg viewBox="0 0 40 32" fill="none">
          <path d="M7 5h26v22H7zM12 24l5-6 4 4 7-9"></path>
        </svg>
      </span>

      <div class="landing-git__diagram">
        <div class="landing-git__branch">
          <span
            class="landing-git__branch-icon landing-git__branch-icon--source"
          >
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M7 6h4v4H7zM13 14h4v4h-4zM13 6h4v4h-4z"></path>
              <path d="M11 8h2M15 10v4"></path>
            </svg>
          </span>
          <span class="landing-git__branch-label">feature/auth-test</span>
        </div>
        <span class="landing-git__arrow">
          <svg viewBox="0 0 29 14" fill="none">
            <path d="M1 7h25M21 3l4 4-4 4"></path>
          </svg>
        </span>
        <div class="landing-git__branch">
          <span
            class="landing-git__branch-icon landing-git__branch-icon--target"
          >
            <svg viewBox="0 0 30 15" fill="none">
              <path d="M1 7.5h28M22 1.5 28 7.5 22 13.5"></path>
            </svg>
          </span>
          <span
            class="landing-git__branch-label landing-git__branch-label--accent"
          >
            Merge to Main
          </span>
        </div>
      </div>

      <div class="landing-git__status">
        <div class="landing-git__status-head">
          <span>Git Workflow</span>
          <span>1m ago</span>
        </div>
        <div class="landing-git__status-bar">
          <span></span>
        </div>
      </div>
    </div>
  </div>

  <div class="landing-git__copy">
    <h2 id="landing-git-heading" class="landing-section-title">
      Engineers Trust Git.
      <br />
      So Do We.
    </h2>
    <p class="landing-section-description landing-git__description">
      Most visual tools lock your tests into a proprietary database. AppraiseJS
      treats code as the source of truth. Every visual change you make is
      committed to your repository as human-readable code.
    </p>

    <div class="landing-git__list">
      {
        bullets.map((bullet) => (
          <article class="landing-git__list-item">
            <span class="landing-git__list-icon" aria-hidden="true">
              <svg viewBox="0 0 24 20" fill="none">
                <path d="M4 10.5 9 15.5 20 4.5" />
              </svg>
            </span>
            <div>
              <h3>{bullet.title}</h3>
              <p>{bullet.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
