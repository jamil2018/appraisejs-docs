---
interface Props {
  /** Expand to fill the parent card body above the title. */
  fill?: boolean;
}

const { fill = false } = Astro.props;
---

<div
  class:list={["dynamic-integrator-demo", fill && "dynamic-integrator-demo--fill"]}
  aria-hidden="true"
>
  <div class="dynamic-integrator-demo__panel">
    <div class="dynamic-integrator-demo__bar">
      <span>custom-step.ts</span>
      <span>integrator</span>
    </div>

    <div class="dynamic-integrator-demo__stage">
      <div class="dynamic-integrator-demo__view dynamic-integrator-demo__view--editor">
        <label class="dynamic-integrator-demo__field">
          <span>Name</span>
          <strong><span>Fill</span></strong>
        </label>

        <div class="dynamic-integrator-demo__editor">
          <div><span class="token-key">step</span>(<span class="token-string">"Fill"</span>, async () =&gt; &#123;</div>
          <div>&nbsp;&nbsp;await page.<span class="token-fn">fill</span>(target, value);</div>
          <div>});</div>
        </div>

        <div class="dynamic-integrator-demo__save">Save step</div>
      </div>

      <div class="dynamic-integrator-demo__view dynamic-integrator-demo__view--canvas">
        <div class="dynamic-integrator-demo__graph">
          <div class="dynamic-integrator-demo__node dynamic-integrator-demo__node--existing"><span>Open</span></div>
          <div class="dynamic-integrator-demo__edge dynamic-integrator-demo__edge--existing"></div>
          <div class="dynamic-integrator-demo__node dynamic-integrator-demo__node--existing"><span>Type</span></div>
          <div class="dynamic-integrator-demo__edge dynamic-integrator-demo__edge--new"></div>
          <div class="dynamic-integrator-demo__node dynamic-integrator-demo__node--fill"><span>Fill</span></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .dynamic-integrator-demo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: clamp(4.5rem, 14vw, 5.75rem);
    padding: 0.65rem 0.5rem;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius);
    background: #101010;
  }

  .dynamic-integrator-demo__panel {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 15rem;
    height: auto;
    overflow: hidden;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius);
    background: #101010;
  }

  .dynamic-integrator-demo__bar {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    border-bottom: 1px solid var(--landing-border);
    color: var(--landing-dim);
    font-family: "Geist Mono", var(--sl-font-mono), monospace;
    font-size: 0.5rem;
    text-transform: lowercase;
  }

  .dynamic-integrator-demo__stage {
    position: relative;
    display: grid;
    flex: 1 1 auto;
    min-height: 10.5rem;
    overflow: hidden;
    background:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      #0e0e0e;
    background-size: 18px 18px;
  }

  .dynamic-integrator-demo__view {
    grid-area: 1 / 1;
    min-width: 0;
  }

  .dynamic-integrator-demo__view--editor {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    padding: 0.55rem;
    animation: dynamic-integrator-editor 6.8s ease-in-out infinite;
  }

  .dynamic-integrator-demo__field {
    display: grid;
    gap: 0.2rem;
    color: var(--landing-dim);
    font-size: 0.5rem;
    line-height: 1;
  }

  .dynamic-integrator-demo__field strong {
    display: flex;
    align-items: center;
    width: 54%;
    min-width: 4.5rem;
    height: 1rem;
    padding: 0 0.35rem;
    overflow: hidden;
    border: 1px solid rgba(16, 185, 129, 0.36);
    border-radius: 3px;
    background: rgba(16, 185, 129, 0.08);
    color: rgba(255, 255, 255, 0.86);
    font-family: "Geist Mono", var(--sl-font-mono), monospace;
    font-size: 0.5rem;
    font-weight: 500;
  }

  .dynamic-integrator-demo__field strong span {
    display: inline-block;
    width: 0;
    overflow: hidden;
    white-space: nowrap;
    animation: dynamic-integrator-name-text 6.8s steps(4, end) infinite;
  }

  .dynamic-integrator-demo__field strong::after {
    content: "";
    display: inline-block;
    flex: 0 0 auto;
    width: 1px;
    height: 0.75em;
    margin-left: 2px;
    vertical-align: -0.05em;
    background: var(--landing-green);
    animation: dynamic-integrator-field-caret 6.8s step-end infinite;
  }

  .dynamic-integrator-demo__editor::after {
    content: "";
    position: absolute;
    right: 0.45rem;
    bottom: 0.45rem;
    display: inline-block;
    width: 1px;
    height: 0.75em;
    background: var(--landing-green);
    animation: dynamic-integrator-code-caret 6.8s step-end infinite;
  }


  .dynamic-integrator-demo__editor {
    position: relative;
    display: grid;
    gap: 0.2rem;
    min-height: 3.1rem;
    padding: 0.45rem;
    overflow: hidden;
    border: 1px solid var(--landing-border);
    border-radius: 3px;
    background: rgba(12, 12, 12, 0.9);
    color: rgba(255, 255, 255, 0.78);
    font-family: "Geist Mono", var(--sl-font-mono), monospace;
    font-size: 0.48rem;
    line-height: 1.45;
  }

  .dynamic-integrator-demo__editor div {
    clip-path: inset(0 100% 0 0);
    white-space: nowrap;
  }

  .dynamic-integrator-demo__editor div:nth-child(1) {
    animation: dynamic-integrator-code-line-1 6.8s steps(32, end) infinite;
  }

  .dynamic-integrator-demo__editor div:nth-child(2) {
    animation: dynamic-integrator-code-line-2 6.8s steps(34, end) infinite;
  }

  .dynamic-integrator-demo__editor div:nth-child(3) {
    animation: dynamic-integrator-code-line-3 6.8s steps(4, end) infinite;
  }

  .dynamic-integrator-demo__save {
    display: grid;
    place-items: center;
    justify-self: start;
    min-width: 4.5rem;
    height: 1rem;
    padding: 0 0.5rem;
    border: 1px solid rgba(16, 185, 129, 0.55);
    border-radius: 3px;
    background: rgba(16, 185, 129, 0.16);
    color: #6ee7b7;
    font-size: 0.46rem;
    font-weight: 620;
    animation: dynamic-integrator-save 6.8s ease-in-out infinite;
  }

  .dynamic-integrator-demo__view--canvas {
    display: grid;
    place-items: center;
    padding: 0.9rem 0.65rem;
    opacity: 0;
    animation: dynamic-integrator-canvas 6.8s ease-in-out infinite;
  }

  .dynamic-integrator-demo__graph {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 16rem;
    min-height: 6rem;
  }

  .dynamic-integrator-demo__edge {
    flex: 0 0 1rem;
    align-self: center;
    height: 3px;
    border-radius: 999px;
    background: rgba(16, 185, 129, 0.46);
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.18);
  }

  .dynamic-integrator-demo__edge--new {
    transform: scaleX(0);
    transform-origin: left center;
    background: #6ee7b7;
    box-shadow: 0 0 12px rgba(110, 231, 183, 0.76);
    animation: dynamic-integrator-new-edge 6.8s ease-in-out infinite;
  }

  .dynamic-integrator-demo__node {
    box-sizing: border-box;
    display: grid;
    flex: 1 1 0;
    align-self: center;
    place-items: center;
    width: 100%;
    max-width: 4.7rem;
    min-width: 0;
    height: 3.35rem;
    min-height: 3.35rem;
    padding: 0;
    border: 1.5px solid rgba(16, 185, 129, 0.48);
    border-radius: 7px;
    background: rgba(18, 18, 18, 0.97);
    color: rgba(255, 255, 255, 0.86);
    font-family: "Geist Mono", var(--sl-font-mono), monospace;
    font-size: clamp(0.66rem, 1.9vw, 0.82rem);
    font-weight: 620;
    line-height: 1;
    text-align: center;
  }

  .dynamic-integrator-demo__node span {
    display: block;
    line-height: 1;
    margin: 0;
    padding: 0;
    transform: translateY(-0.01em);
  }

  .dynamic-integrator-demo__node--fill {
    opacity: 0;
    transform-origin: center;
    animation: dynamic-integrator-fill-node 6.8s ease-in-out infinite;
  }

  .dynamic-integrator-demo__node--fill {
    border-color: #6ee7b7;
    background: rgba(16, 185, 129, 0.18);
    color: #d1fae5;
    box-shadow: 0 0 18px rgba(16, 185, 129, 0.28);
  }

  .dynamic-integrator-demo--fill {
    flex: 1 1 auto;
    align-items: center;
    justify-content: center;
    min-height: 0;
    width: 100%;
    height: 100%;
    padding: clamp(0.75rem, 3vw, 1.25rem);
    border: 0;
    border-radius: 0;
    background: transparent;
  }

  .dynamic-integrator-demo--fill .dynamic-integrator-demo__panel {
    width: 100%;
    max-width: none;
    height: 100%;
  }

  .dynamic-integrator-demo--fill .dynamic-integrator-demo__stage {
    min-height: 0;
  }

  @keyframes dynamic-integrator-editor {
    0%,
    52% {
      opacity: 1;
      transform: translateY(0);
    }
    58%,
    100% {
      opacity: 0;
      transform: translateY(-0.4rem);
    }
  }

  @keyframes dynamic-integrator-canvas {
    0%,
    54%,
    94%,
    100% {
      opacity: 0;
      transform: translateY(0.35rem);
    }
    60%,
    88% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes dynamic-integrator-field-caret {
    0%,
    8%,
    20%,
    32%,
    44%,
    100% {
      opacity: 1;
    }
    4%,
    14%,
    26%,
    38%,
    52%,
    100% {
      opacity: 0;
    }
    55% {
      opacity: 0;
    }
  }

  @keyframes dynamic-integrator-name-text {
    0%,
    7%,
    58%,
    100% {
      width: 0;
    }
    17%,
    52% {
      width: 4ch;
    }
  }

  @keyframes dynamic-integrator-code-caret {
    0%,
    20%,
    55%,
    100% {
      opacity: 0;
    }
    24%,
    50% {
      opacity: 1;
    }
  }

  @keyframes dynamic-integrator-code-line-1 {
    0%,
    20%,
    58%,
    100% {
      clip-path: inset(0 100% 0 0);
    }
    30%,
    52% {
      clip-path: inset(0 0 0 0);
    }
  }

  @keyframes dynamic-integrator-code-line-2 {
    0%,
    31%,
    58%,
    100% {
      clip-path: inset(0 100% 0 0);
    }
    42%,
    52% {
      clip-path: inset(0 0 0 0);
    }
  }

  @keyframes dynamic-integrator-code-line-3 {
    0%,
    43%,
    58%,
    100% {
      clip-path: inset(0 100% 0 0);
    }
    48%,
    52% {
      clip-path: inset(0 0 0 0);
    }
  }

  @keyframes dynamic-integrator-save {
    0%,
    40%,
    100% {
      transform: scale(1);
      box-shadow: none;
    }
    46%,
    50% {
      transform: scale(0.96);
      box-shadow: 0 0 16px rgba(16, 185, 129, 0.22);
    }
  }

  @keyframes dynamic-integrator-fill-node {
    0%,
    62%,
    94%,
    100% {
      opacity: 0;
      transform: scale(0.78);
    }
    68%,
    88% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes dynamic-integrator-new-edge {
    0%,
    68%,
    94%,
    100% {
      transform: scaleX(0);
      opacity: 0;
    }
    74%,
    88% {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  @media (max-width: 760px) {
    .dynamic-integrator-demo:not(.dynamic-integrator-demo--fill) {
      min-height: 4.25rem;
      padding: 0.5rem 0.35rem;
    }

    .dynamic-integrator-demo--fill .dynamic-integrator-demo__stage {
      min-height: 9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dynamic-integrator-demo__view--editor,
    .dynamic-integrator-demo__view--canvas,
    .dynamic-integrator-demo__save,
    .dynamic-integrator-demo__node--fill,
    .dynamic-integrator-demo__edge--new {
      animation: none;
    }

    .dynamic-integrator-demo__view--editor {
      opacity: 0;
    }

    .dynamic-integrator-demo__view--canvas,
    .dynamic-integrator-demo__node--fill,
    .dynamic-integrator-demo__edge--new {
      opacity: 1;
    }

    .dynamic-integrator-demo__edge--new {
      transform: scaleX(1);
    }

    .dynamic-integrator-demo__editor div {
      clip-path: inset(0 0 0 0);
    }
  }
</style>
