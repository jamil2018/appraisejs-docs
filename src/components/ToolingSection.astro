---
import { Crosshair, FileCode2, MousePointer2, TerminalSquare } from "@lucide/astro";
---

<section class="tool-showcase landing-shell" aria-labelledby="locator-heading">
  <div class="tool-showcase__copy">
    <p class="landing-kicker">Locator Creator</p>
    <h2 id="locator-heading" class="landing-section-title">
      Selectors captured with intent, not guesswork.
    </h2>
    <p class="landing-section-description">
      Capture target elements, inspect candidate strategies, and keep locator
      groups tied to the workflows that consume them.
    </p>
  </div>

  <div class="locator-panel">
    <div class="locator-panel__browser">
      <div class="landing-panel__bar">
        <span>checkout.local</span>
        <span>inspect mode</span>
      </div>
      <div class="locator-panel__page" aria-hidden="true">
        <span class="locator-panel__field"></span>
        <span class="locator-panel__field locator-panel__field--short"></span>
        <span class="locator-panel__target">
          <Crosshair />
        </span>
      </div>
    </div>
    <div class="locator-panel__details">
      <span class="tool-icon" aria-hidden="true"><MousePointer2 /></span>
      <h3>Primary checkout button</h3>
      <dl>
        <div><dt>Role</dt><dd>button</dd></div>
        <div><dt>Name</dt><dd>Complete order</dd></div>
        <div><dt>Fallback</dt><dd>data-testid="submit-order"</dd></div>
      </dl>
    </div>
  </div>
</section>

<section class="tool-showcase tool-showcase--reverse landing-shell" aria-labelledby="integrator-heading">
  <div class="tool-showcase__copy">
    <p class="landing-kicker">Dynamic Step Integrator</p>
    <h2 id="integrator-heading" class="landing-section-title">
      Custom automation steps become reusable visual building blocks.
    </h2>
    <p class="landing-section-description">
      Bring domain-specific Playwright helpers into the builder without turning
      the generated output into a black box.
    </p>
  </div>

  <div class="integrator-panel">
    <div class="landing-panel__bar">
      <span>dynamic-steps.ts</span>
      <span>registered</span>
    </div>
    <pre><code><span class="token-key">registerStep</span>(&#123;
  name: <span class="token-string">"Apply coupon"</span>,
  inputs: [<span class="token-string">"code"</span>],
  run: async (&#123; page, code &#125;) =&gt; &#123;
    await page.getByLabel(<span class="token-string">"Coupon"</span>).fill(code);
    await page.getByRole(<span class="token-string">"button"</span>, &#123; name: <span class="token-string">"Apply"</span> &#125;).click();
  &#125;,
&#125;);</code></pre>
    <div class="integrator-panel__footer">
      <span><FileCode2 aria-hidden="true" /> emitted as support code</span>
      <span><TerminalSquare aria-hidden="true" /> runnable in CI</span>
    </div>
  </div>
</section>
