<section
  class="landing-navbar"
  aria-label="Landing navigation"
  id="landing-navbar"
>
  <strong class="landing-navbar__brand">
    <svg class="landing-navbar__logo" viewBox="0 0 128 128" aria-hidden="true">
      <line
        class="ln"
        x1="14"
        y1="64"
        x2="62"
        y2="64"
        stroke-width="4.5"
        stroke-linecap="round"></line>
      <circle class="dot" cx="16" cy="64" r="6.5" stroke-width="3.5"></circle>
      <circle class="dot" cx="42" cy="64" r="8.5" stroke-width="3.5"></circle>
      <circle class="ring" cx="88" cy="64" r="26" fill="none" stroke-width="7"
      ></circle>
      <polyline
        class="ck"
        points="76,66 85,76 102,54"
        fill="none"
        stroke-width="6.5"
        stroke-linecap="round"
        stroke-linejoin="round"></polyline>
    </svg>
    AppraiseJS
  </strong>
  <button
    type="button"
    class="landing-navbar__hamburger"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="landing-navbar-menu"
    id="landing-navbar-hamburger"
  >
    <span class="landing-navbar__hamburger-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>
  <nav
    class="landing-navbar__links"
    id="landing-navbar-menu"
    aria-label="Landing sections"
  >
    <a href="/getting-started/overview/">Product</a>
    <a href="/architecture/overview/">Architecture</a>
    <a href="/guides/dashboard/">Guides</a>
    <a
      href="/getting-started/quick_start/"
      class="landing-cta-button text-white!"
    >
      Get Started
    </a>
  </nav>
</section>

<script>
  const navbar = document.getElementById("landing-navbar");
  const hamburger = document.getElementById("landing-navbar-hamburger");
  const menu = document.getElementById("landing-navbar-menu");

  if (navbar && hamburger && menu) {
    const closeMenu = () => {
      navbar.classList.remove("is-open");
      hamburger.setAttribute("aria-expanded", "false");
    };

    hamburger.addEventListener("click", () => {
      const isOpen = navbar.classList.toggle("is-open");
      hamburger.setAttribute("aria-expanded", String(isOpen));
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });
  }
</script>
