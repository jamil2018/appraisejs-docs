<section class="landing-navbar-shell" aria-label="Landing navigation">
  <div class="landing-navbar" id="landing-navbar">
    <a class="landing-navbar__brand" href="/getting-started/overview/">
      <img class="landing-navbar__logo" src="/logo.svg" alt="" />
      <span>AppraiseJS</span>
    </a>

    <button
      type="button"
      class="landing-navbar__hamburger"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="landing-navbar-menu"
      id="landing-navbar-hamburger"
    >
      <span class="landing-navbar__hamburger-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <nav
      class="landing-navbar__links"
      id="landing-navbar-menu"
      aria-label="Primary"
    >
      <a href="/getting-started/overview/">Docs</a>
      <a href="/references/step_parameter_conventions/">API</a>
      <a
        href="https://github.com/jamil2018/appraisejs-core/releases"
        target="_blank"
        rel="noopener noreferrer"
      >
        Changelog
      </a>
      <a
        href="/getting-started/quick_start/"
        class="landing-navbar__mobile-cta landing-cta-button"
      >
        Get Started
      </a>
    </nav>

    <a href="/getting-started/quick_start/" class="landing-cta-button">
      Get Started
    </a>
  </div>
</section>

<script>
  const navbar = document.getElementById("landing-navbar");
  const hamburger = document.getElementById("landing-navbar-hamburger");
  const menu = document.getElementById("landing-navbar-menu");

  if (navbar && hamburger && menu) {
    const closeMenu = () => {
      navbar.classList.remove("is-open");
      hamburger.setAttribute("aria-expanded", "false");
    };

    hamburger.addEventListener("click", () => {
      const isOpen = navbar.classList.toggle("is-open");
      hamburger.setAttribute("aria-expanded", String(isOpen));
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });
  }
</script>
