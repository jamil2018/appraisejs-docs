---
import FlowBuilderGraph from "./FlowBuilderGraph.astro";
import LocatorCreatorDemo from "./LocatorCreatorDemo.astro";
import DynamicIntegratorDemo from "./DynamicIntegratorDemo.astro";
import {
  Blocks,
  Code,
  Database,
  GitFork,
  ShieldCheck,
  Wrench,
} from "@lucide/astro";

const features = [
  {
    title: "Intuitive Test Flow Builder",
    description:
      "Build test flows visually with an interface that is easy to understand, compose and reuse across various scenarios.",
    icon: GitFork,
  },
  {
    title: "Locator Creator",
    description:
      "Capture resilient selectors with context instead of hand-maintaining brittle CSS paths.",
    icon: ShieldCheck,
  },
  {
    title: "Dynamic Node Builder",
    description:
      "Build custom nodes and expose them inside the worflow builder as first-class actions and assertions.",
    icon: Blocks,
  },
  {
    title: "Portable Output",
    description:
      "Generate Playwright, Cucumber, and support files that stay readable in git and version controlled.",
    icon: Code,
  },
  {
    title: "Local-First",
    description:
      "Run on developer machines and CI without routing execution through a hosted runner.",
    icon: Database,
  },
  {
    title: "All In One Workspace",
    description:
      "Author, execute, and analyze tests from a singular location. No more context switching.",
    icon: Wrench,
  },
];
---

<section
  class="landing-features landing-shell"
  aria-labelledby="features-heading"
>
  <div class="landing-section-copy">
    <p class="landing-kicker">What is in AppraiseJS?</p>
    <h2 id="features-heading" class="landing-section-title">
      Everything you need to author reliable tests that scale with your project.
    </h2>
  </div>

  <div class="feature-grid not-content">
    {
      features.map((feature, index) => {
        const Icon = feature.icon;
        const isFlowBuilder = index === 0;
        const isLocatorCreator = index === 1;
        const isDynamicIntegrator = index === 2;
        const hasAnimation =
          isFlowBuilder || isLocatorCreator || isDynamicIntegrator;
        return (
          <article
            class:list={[
              "feature-card",
              hasAnimation && "feature-card--with-animation",
              isFlowBuilder && "feature-card--flow-builder",
              isLocatorCreator && "feature-card--locator-creator",
              isDynamicIntegrator && "feature-card--dynamic-integrator",
            ]}
          >
            {isFlowBuilder ? (
              <>
                <div class="feature-card__animation">
                  <FlowBuilderGraph fill />
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </>
            ) : isLocatorCreator ? (
              <>
                <div class="feature-card__animation">
                  <LocatorCreatorDemo fill />
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </>
            ) : isDynamicIntegrator ? (
              <>
                <div class="feature-card__animation">
                  <DynamicIntegratorDemo fill />
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </>
            ) : (
              <>
                <span class="feature-card__icon" aria-hidden="true">
                  <Icon />
                </span>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </>
            )}
          </article>
        );
      })
    }
  </div>
</section>

<section
  class="landing-showcase landing-showcase--wide"
  aria-labelledby="workflow-heading"
>
  <div class="landing-shell landing-shell--wide">
    <div class="landing-section-copy">
      <p class="landing-kicker">Execution model</p>
      <h2 id="workflow-heading" class="landing-section-title">
        Build the workflow once. Emit real automation every time.
      </h2>
    </div>

    <div class="workflow-canvas">
      <div class="workflow-canvas__lane">
        <article>
          <span>Create</span>
          <strong>Checkout Scenario</strong>
          <p>Visual steps, grouped logic, and reusable test data.</p>
        </article>
        <article>
          <span>Configure</span>
          <strong>Locators + Parameters</strong>
          <p>Selectors and runtime inputs stay explicit.</p>
        </article>
        <article>
          <span>Execute</span>
          <strong>Playwright Runner</strong>
          <p>Runs locally, in CI, or anywhere your repo runs.</p>
        </article>
        <article>
          <span>Generated Output</span>
          <strong>.feature / .spec / reports</strong>
          <p>Artifacts are readable, portable, and versioned.</p>
        </article>
      </div>
    </div>
  </div>
</section>
