---
import { Boxes, Braces, Code2, Database, GitFork, ShieldCheck } from "@lucide/astro";

const features = [
  {
    title: "Flow Builder 2.0",
    description: "Compose browser journeys as structured blocks, branches, and reusable step groups.",
    icon: GitFork,
  },
  {
    title: "Locator Creator",
    description: "Capture resilient selectors with context instead of hand-maintaining brittle CSS paths.",
    icon: ShieldCheck,
  },
  {
    title: "Dynamic Integrator",
    description: "Register custom steps and expose them inside the builder as first-class actions.",
    icon: Boxes,
  },
  {
    title: "Portable Output",
    description: "Generate Playwright, Cucumber, and support files that stay readable in git.",
    icon: Code2,
  },
  {
    title: "Local-First",
    description: "Run on developer machines and CI without routing execution through a hosted runner.",
    icon: Database,
  },
  {
    title: "Structured Engine",
    description: "Keep workflows deterministic with explicit inputs, artifacts, and execution state.",
    icon: Braces,
  },
];
---

<section class="landing-features landing-shell" aria-labelledby="features-heading">
  <div class="landing-section-copy">
    <p class="landing-kicker">Operational surface</p>
    <h2 id="features-heading" class="landing-section-title">
      Designed for teams that need the visual layer and the code layer to agree.
    </h2>
  </div>

  <div class="feature-grid" data-reveal-group>
    {
      features.map((feature) => {
        const Icon = feature.icon;
        return (
          <article class="feature-card" data-reveal>
            <span class="feature-card__icon" aria-hidden="true"><Icon /></span>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        );
      })
    }
  </div>
</section>

<section class="landing-showcase landing-showcase--wide" aria-labelledby="workflow-heading">
  <div class="landing-shell landing-shell--wide">
    <div class="landing-section-copy">
      <p class="landing-kicker">Execution model</p>
      <h2 id="workflow-heading" class="landing-section-title">
        Build the workflow once. Emit real automation every time.
      </h2>
    </div>

    <div class="workflow-canvas" data-reveal>
      <div class="workflow-canvas__lane">
        <article>
          <span>Create</span>
          <strong>Checkout Scenario</strong>
          <p>Visual steps, grouped logic, and reusable test data.</p>
        </article>
        <article>
          <span>Configure</span>
          <strong>Locators + Parameters</strong>
          <p>Selectors and runtime inputs stay explicit.</p>
        </article>
        <article>
          <span>Execute</span>
          <strong>Playwright Runner</strong>
          <p>Runs locally, in CI, or anywhere your repo runs.</p>
        </article>
        <article>
          <span>Generated Output</span>
          <strong>.feature / .spec / reports</strong>
          <p>Artifacts are readable, portable, and versioned.</p>
        </article>
      </div>
    </div>
  </div>
</section>

<script>
  // @ts-nocheck
  import { animate, inView, stagger } from "motion";

  const revealState = (window.__appraiseLandingReveal ??= { cleanup: [] });

  function initReveals() {
    revealState.cleanup.forEach((cleanup) => cleanup?.());
    revealState.cleanup = [];

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const groups = document.querySelectorAll("[data-reveal-group]");
    const singles = document.querySelectorAll("[data-reveal]:not([data-reveal-group] [data-reveal])");

    if (reduce) {
      document.querySelectorAll("[data-reveal]").forEach((item) => item.classList.add("is-visible"));
      return;
    }

    groups.forEach((group) => {
      const cleanup = inView(group, () => {
        const items = group.querySelectorAll("[data-reveal]");
        items.forEach((item) => item.classList.add("is-visible"));
        animate(items, { opacity: [0, 1], y: [18, 0] }, { duration: 0.32, delay: stagger(0.06) });
      }, { margin: "-15% 0px" });
      revealState.cleanup.push(cleanup);
    });

    singles.forEach((item) => {
      const cleanup = inView(item, () => {
        item.classList.add("is-visible");
        animate(item, { opacity: [0, 1], y: [18, 0] }, { duration: 0.34 });
      }, { margin: "-15% 0px" });
      revealState.cleanup.push(cleanup);
    });
  }

  document.addEventListener("astro:page-load", initReveals);
  document.addEventListener("astro:before-swap", () => revealState.cleanup.forEach((cleanup) => cleanup?.()));
  initReveals();
</script>
