---
interface Props {
  /** Expand to fill the parent card body above the title. */
  fill?: boolean;
}

const { fill = false } = Astro.props;
const cycle = "7.2s";
---

<div
  class:list={["all-in-one-demo", fill && "all-in-one-demo--fill"]}
  style={`--all-in-one-cycle: ${cycle}`}
  aria-hidden="true"
>
  <div class="all-in-one-demo__panel">
    <div class="all-in-one-demo__stage">
      <div class="all-in-one-demo__view all-in-one-demo__view--canvas">
        <div class="all-in-one-demo__window all-in-one-demo__window--canvas">
          <div class="all-in-one-demo__title">Create Test Case</div>
          <div class="all-in-one-demo__canvas-grid">
            <span class="all-in-one-demo__node all-in-one-demo__node--start"
            ></span>
            <span class="all-in-one-demo__edge all-in-one-demo__edge--one"
            ></span>
            <span class="all-in-one-demo__node all-in-one-demo__node--open"
            ></span>
            <span class="all-in-one-demo__edge all-in-one-demo__edge--two"
            ></span>
            <span class="all-in-one-demo__node all-in-one-demo__node--fill"
            ></span>
            <span class="all-in-one-demo__edge all-in-one-demo__edge--three"
            ></span>
            <span class="all-in-one-demo__node all-in-one-demo__node--assert"
            ></span>
            <span class="all-in-one-demo__edge all-in-one-demo__edge--four"
            ></span>
            <span class="all-in-one-demo__node all-in-one-demo__node--done"
            ></span>
          </div>
        </div>
      </div>

      <div class="all-in-one-demo__view all-in-one-demo__view--run">
        <div class="all-in-one-demo__window">
          <div class="all-in-one-demo__title">Create Test Run</div>
          <div class="all-in-one-demo__form">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="all-in-one-demo__button">Start Test Run</div>
          <span class="all-in-one-demo__cursor"></span>
        </div>
      </div>

      <div class="all-in-one-demo__view all-in-one-demo__view--report">
        <div class="all-in-one-demo__window all-in-one-demo__window--report">
          <div class="all-in-one-demo__title">Test Report</div>
          <div class="all-in-one-demo__report-main">
            <div class="all-in-one-demo__report-list">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="all-in-one-demo__chart">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
          <div class="all-in-one-demo__table">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .all-in-one-demo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: clamp(4.5rem, 14vw, 5.75rem);
    padding: 0.65rem 0.5rem;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius);
    background: #101010;
  }

  .all-in-one-demo__panel {
    display: flex;
    width: 100%;
    max-width: 15rem;
    min-height: 10rem;
    overflow: hidden;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius);
    background: #101010;
  }

  .all-in-one-demo__stage {
    position: relative;
    display: grid;
    flex: 1 1 auto;
    min-height: 100%;
    overflow: hidden;
    perspective: 780px;
    background:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      #0e0e0e;
    background-size: 22px 22px;
  }

  .all-in-one-demo__view {
    position: relative;
    grid-area: 1 / 1;
    display: grid;
    min-width: 0;
    padding: clamp(0.75rem, 2.5vw, 1.2rem);
    transform-origin: center;
  }

  .all-in-one-demo__view--canvas {
    place-items: center;
    animation: all-in-one-canvas var(--all-in-one-cycle) ease-in-out infinite;
  }

  .all-in-one-demo__view--run {
    place-items: center;
    opacity: 0;
    transform: translate(1.4rem, 0.75rem) rotate(1.5deg) scale(0.96);
    animation: all-in-one-run var(--all-in-one-cycle) ease-in-out infinite;
  }

  .all-in-one-demo__view--report {
    place-items: center;
    opacity: 0;
    transform: translateY(1.15rem) scale(0.96);
    animation: all-in-one-report var(--all-in-one-cycle) ease-in-out infinite;
  }

  .all-in-one-demo__window--canvas {
    width: min(100%, 34rem);
    min-height: 9.5rem;
  }

  .all-in-one-demo__canvas-grid {
    position: relative;
    width: min(100%, 28rem);
    aspect-ratio: 16 / 5.2;
    justify-self: center;
  }

  .all-in-one-demo__node,
  .all-in-one-demo__edge {
    position: absolute;
    display: block;
    opacity: 0;
  }

  .all-in-one-demo__node {
    width: clamp(1.15rem, 4vw, 1.85rem);
    aspect-ratio: 1;
    border: 1px solid rgba(110, 231, 183, 0.68);
    border-radius: 6px;
    background: rgba(16, 185, 129, 0.16);
    box-shadow: 0 0 18px rgba(16, 185, 129, 0.24);
    transform: scale(0.68);
    animation: all-in-one-node var(--all-in-one-cycle) ease-out infinite;
  }

  .all-in-one-demo__node::after {
    content: "";
    position: absolute;
    inset: 34%;
    border-radius: 999px;
    background: #6ee7b7;
  }

  .all-in-one-demo__edge {
    height: 3px;
    border-radius: 999px;
    background: rgba(110, 231, 183, 0.78);
    box-shadow: 0 0 12px rgba(110, 231, 183, 0.35);
    transform: scaleX(0);
    transform-origin: left center;
    animation: all-in-one-edge var(--all-in-one-cycle) ease-out infinite;
  }

  .all-in-one-demo__node--start {
    left: 2%;
    top: 42%;
    animation-delay: 0s;
  }

  .all-in-one-demo__edge--one {
    left: 9.5%;
    top: calc(40% + 0.85rem);
    width: 15%;
    animation-delay: 0.2s;
  }

  .all-in-one-demo__node--open {
    left: 26%;
    top: 42%;
    animation-delay: 0.38s;
  }

  .all-in-one-demo__edge--two {
    left: 33.5%;
    top: calc(40% + 0.85rem);
    width: 15%;
    animation-delay: 0.58s;
  }

  .all-in-one-demo__node--fill {
    left: 50%;
    top: 42%;
    animation-delay: 0.78s;
  }

  .all-in-one-demo__edge--three {
    left: 57.5%;
    top: calc(42% + 0.85rem);
    width: 15%;
    animation-delay: 1.02s;
  }

  .all-in-one-demo__node--assert {
    left: 74%;
    top: 42%;
    animation-delay: 1.24s;
  }

  .all-in-one-demo__edge--four {
    left: 81.5%;
    top: calc(42% + 0.85rem);
    width: 8%;
    animation-delay: 1.44s;
  }

  .all-in-one-demo__node--done {
    left: 91%;
    top: 42%;
    animation-delay: 1.64s;
  }

  .all-in-one-demo__window {
    position: relative;
    display: grid;
    align-content: start;
    gap: clamp(0.5rem, 1.8vw, 0.75rem);
    width: min(100%, 31rem);
    height: 100%;
    min-height: 10rem;
    padding: clamp(0.75rem, 2.5vw, 1rem);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 6px;
    background: rgba(18, 18, 18, 0.98);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.24);
  }

  .all-in-one-demo__title {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.62rem, 1.65vw, 0.84rem);
    font-weight: 650;
    line-height: 1.15;
  }

  .all-in-one-demo__form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .all-in-one-demo__form span,
  .all-in-one-demo__report-list span,
  .all-in-one-demo__table span {
    display: block;
    min-height: clamp(1rem, 3vw, 1.35rem);
    border: 1px solid var(--landing-border-soft);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.07);
  }

  .all-in-one-demo__form span:nth-child(1),
  .all-in-one-demo__form span:nth-child(4) {
    grid-column: 1 / -1;
  }

  .all-in-one-demo__button {
    display: grid;
    place-items: center;
    justify-self: start;
    min-width: min(100%, 8.5rem);
    min-height: 2rem;
    padding-inline: 0.75rem;
    border: 1px solid rgba(16, 185, 129, 0.58);
    border-radius: 4px;
    background: rgba(16, 185, 129, 0.18);
    color: #d1fae5;
    font-size: clamp(0.58rem, 1.5vw, 0.76rem);
    font-weight: 650;
    animation: all-in-one-button var(--all-in-one-cycle) ease-in-out infinite;
  }

  .all-in-one-demo__cursor {
    position: absolute;
    left: clamp(5.5rem, 23vw, 8.2rem);
    top: clamp(6.3rem, 21vw, 8.2rem);
    width: 0.7rem;
    height: 0.7rem;
    border-right: 2px solid #ffffff;
    border-bottom: 2px solid #ffffff;
    transform: rotate(45deg);
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.35));
    animation: all-in-one-cursor var(--all-in-one-cycle) ease-in-out infinite;
  }

  .all-in-one-demo__window--report {
    width: min(100%, 34rem);
    gap: 0.55rem;
  }

  .all-in-one-demo__report-main {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
    gap: 0.6rem;
    min-height: 0;
  }

  .all-in-one-demo__report-list {
    display: grid;
    gap: 0.35rem;
  }

  .all-in-one-demo__report-list span:nth-child(2) {
    width: 84%;
  }

  .all-in-one-demo__report-list span:nth-child(3) {
    width: 70%;
  }

  .all-in-one-demo__report-list span:nth-child(4) {
    width: 92%;
  }

  .all-in-one-demo__chart {
    position: relative;
    min-height: clamp(4rem, 15vw, 7rem);
    overflow: hidden;
    border: 1px solid var(--landing-border-soft);
    border-radius: 4px;
    background:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      rgba(255, 255, 255, 0.04);
    background-size: 18px 18px;
  }

  .all-in-one-demo__chart span {
    position: absolute;
    bottom: 0.6rem;
    width: 16%;
    border-radius: 4px 4px 0 0;
    background: rgba(16, 185, 129, 0.44);
    box-shadow: 0 0 16px rgba(16, 185, 129, 0.18);
  }

  .all-in-one-demo__chart span:nth-child(1) {
    left: 15%;
    height: 46%;
  }

  .all-in-one-demo__chart span:nth-child(2) {
    left: 42%;
    height: 76%;
    background: rgba(59, 130, 246, 0.48);
  }

  .all-in-one-demo__chart span:nth-child(3) {
    left: 69%;
    height: 58%;
  }

  .all-in-one-demo__table {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.35rem;
    width: 100%;
  }

  .all-in-one-demo--fill {
    flex: 1 1 auto;
    align-items: stretch;
    justify-content: stretch;
    min-height: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
  }

  .all-in-one-demo--fill .all-in-one-demo__panel {
    max-width: none;
    min-height: 0;
    border: 0;
    border-radius: 0;
  }

  @keyframes all-in-one-canvas {
    0%,
    32% {
      opacity: 1;
      transform: translate(0, 0) rotate(0) scale(1);
    }
    39%,
    100% {
      opacity: 0;
      transform: translate(-1.2rem, -0.35rem) rotate(-1.4deg) scale(0.97);
    }
  }

  @keyframes all-in-one-run {
    0%,
    33%,
    100% {
      opacity: 0;
      transform: translate(1.4rem, 0.75rem) rotate(1.5deg) scale(0.96);
    }
    40%,
    60% {
      opacity: 1;
      transform: translate(0, 0) rotate(0) scale(1);
    }
    67% {
      opacity: 0;
      transform: translate(-1.3rem, -0.55rem) rotate(-1deg) scale(0.98);
    }
  }

  @keyframes all-in-one-report {
    0%,
    64%,
    100% {
      opacity: 0;
      transform: translateY(1.15rem) scale(0.96);
    }
    72%,
    94% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes all-in-one-node {
    0%,
    2% {
      opacity: 0;
      transform: scale(0.68);
    }
    6%,
    35% {
      opacity: 1;
      transform: scale(1);
    }
    39%,
    100% {
      opacity: 0;
      transform: scale(0.94);
    }
  }

  @keyframes all-in-one-edge {
    0%,
    2% {
      opacity: 0;
      transform: scaleX(0);
    }
    6%,
    35% {
      opacity: 1;
      transform: scaleX(1);
    }
    39%,
    100% {
      opacity: 0;
      transform: scaleX(1);
    }
  }

  @keyframes all-in-one-cursor {
    0%,
    43%,
    49%,
    65%,
    100% {
      opacity: 0;
      transform: translate(-0.6rem, -0.5rem) rotate(45deg);
    }
    51%,
    55% {
      opacity: 1;
      transform: translate(0, 0) rotate(45deg);
    }
    57%,
    59% {
      opacity: 1;
      transform: translate(0, 0) rotate(45deg) scale(0.84);
    }
  }

  @keyframes all-in-one-button {
    0%,
    54%,
    60%,
    100% {
      transform: scale(1);
      box-shadow: none;
    }
    57% {
      transform: scale(0.96);
      box-shadow: 0 0 18px rgba(16, 185, 129, 0.25);
    }
  }

  @media (max-width: 760px) {
    .all-in-one-demo:not(.all-in-one-demo--fill) {
      min-height: 4.25rem;
      padding: 0.5rem 0.35rem;
    }

    .all-in-one-demo__view {
      padding: 0.65rem;
    }

    .all-in-one-demo__report-main {
      grid-template-columns: 1fr;
    }

    .all-in-one-demo__chart {
      min-height: 3.4rem;
    }

    .all-in-one-demo__table {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .all-in-one-demo__view,
    .all-in-one-demo__node,
    .all-in-one-demo__edge,
    .all-in-one-demo__cursor,
    .all-in-one-demo__button {
      animation: none;
    }

    .all-in-one-demo__view--canvas,
    .all-in-one-demo__view--run {
      opacity: 0;
    }

    .all-in-one-demo__view--report {
      opacity: 1;
      transform: none;
    }

    .all-in-one-demo__node,
    .all-in-one-demo__edge {
      opacity: 1;
    }

    .all-in-one-demo__edge {
      transform: scaleX(1);
    }

    .all-in-one-demo__edge--two,
    .all-in-one-demo__edge--four {
      transform: scaleX(1);
    }
  }
</style>
